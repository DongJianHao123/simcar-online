{
  "name": "simulator-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:frontend": "vite build",
    "build:backend": "tsc --project tsconfig.json",
    "build": "npm run build:frontend && npm run build:backend",
    "dev:backend": "ts-node --project tsconfig.json src/main.ts",
    "dev:frontend": "vite",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start": "ts-node --project tsconfig.json src/main.ts",
    "start:prod": "node dist/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/serve-static": "^4.0.0",
    "@nestjs/websockets": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.3",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/three": "^0.183.0",
    "concurrently": "^9.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
